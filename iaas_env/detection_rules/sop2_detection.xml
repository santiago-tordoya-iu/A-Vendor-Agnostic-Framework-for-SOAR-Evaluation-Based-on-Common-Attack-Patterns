<group name="atomic_red_team,">

  <rule id="100002" level="16">
    <if_group>sysmon_event1</if_group>
    
    <field name="win.eventdata.originalFileName" type="pcre2">(?i)mimikatz\.exe</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)kerberos::golden</field>
    
    <description>CASS T1558.001 detected: Mimikatz Golden Ticket creation (T1558.001) on $(win.system.computer)</description>
    
    <mitre>
      <id>T1558.001</id>
    </mitre>
   
    <options>no_full_log</options>
  </rule>

</group>

      "options": {
        "mode": "message_only",
        "loop": false,
        "payload": "=MAP_LAMBDA(\n  LOCAL.kill_chain_phases,\n  LAMBDA(\n   phase,\n  SET_KEY(phase, \"techniques\", COMPACT(FLATTEN(MAP_LAMBDA(implode_detailed_intrusion_sets,\n    LAMBDA(intrusion_set,\n      FILTER(intrusion_set.techniques,\n        LAMBDA(technique, technique.tactic=phase.name)))\n  )))|> MAP_LAMBDA(UNIQ(MAP(%, \"techniqueID\")), LAMBDA(technique_id,\n    OBJECT(\n      \"techniqeID\", technique_id,\n      \"technique\", WHERE(%, \"techniqueID\", technique_id)[0].technique,\n      \"count\", COUNTIF(MAP(%, \"techniqueID\"),technique_id))))\n    |> SLICE_ARRAY(REVERSE(SORT(%,\"count\")), 0,5)\n  )))\n|> FILTER(%, LAMBDA(phase, NOT(IS_BLANK(phase.techniques))))",

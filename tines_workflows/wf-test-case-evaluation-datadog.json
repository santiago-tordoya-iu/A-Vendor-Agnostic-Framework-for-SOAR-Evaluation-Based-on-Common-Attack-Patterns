      "schedule": null
    },
    {
      "type": "Agents::EventTransformationAgent",
      "name": "Scorecard per SOP",
      "disabled": false,
      "description": null,
      "guid": "089edfade98329b3e0b8da581242a7fd",
      "origin_story_identifier": "cloud:0224858beecd9378f9a79657235a144b:236261b69a0ad4d1e7faf50a60261900",
      "options": {
        "mode": "message_only",
        "loop": false,
        "payload": {
          "test_case": "=SWITCH(\n  TRUE,\n  IS_PRESENT(sop1_executions),\n  \"SOP1\",\n  IS_PRESENT(sop2_executions),\n  \"SOP2\",\n  IS_PRESENT(sop3_executions),\n  \"SOP3\",\n  IS_PRESENT(sop4_executions),\n  \"SOP4\",\n  IS_PRESENT(sop5_executions),\n  \"SOP5\",\n  IS_PRESENT(sop6_executions),\n  \"SOP6\",\n  IS_PRESENT(sop7_executions),\n  \"SOP7\",\n  IS_PRESENT(sop8_executions),\n  \"SOP8\",\n  \"SOP9\"\n)",
          "mttd": "=AVERAGE(MAP(LOCAL.runs,\"['Time to Detect']\"))",
          "mttr": "=AVERAGE(MAP(LOCAL.runs,\"['Time to Respond']\"))",
          "mttc": "=AVERAGE(MAP(LOCAL.runs,\"['Time to Control']\"))",
          "mspt": "=AVERAGE(MAP(LOCAL.runs,\"['SOAR Processing Time']\"))",
          "csr": "=ROUND(AVERAGE(MAP(LOCAL.runs,\"['Containment Success']\"))*100,2)",
          "mec": "=AVERAGE(MAP(LOCAL.runs,\"['Event Consumption']\"))",
          "mcpe": "=AVERAGE(MAP(LOCAL.runs,\"['Cost per Execution']\"))"
        },
        "local": {
          "runs": "=FLATTEN(MAP_LAMBDA(implode_executions, LAMBDA(execution, VALUES(execution))))"
        }
      },
      "reporting": {
        "time_saved_value": 0,
        "time_saved_unit": "minutes"
      },

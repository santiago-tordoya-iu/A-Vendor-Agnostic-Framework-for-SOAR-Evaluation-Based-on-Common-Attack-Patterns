        "name": "Summary",
        "actionId": "com.datadoghq.datatransformation.func",
        "parameters": [
          {
            "name": "script",
            "value": "const controlStepNames = [\n  \"SOP1_Time_to_Control\",\n  \"SOP2_Time_to_Control\",\n  \"SOP3_Time_to_Control\",\n  \"SOP4_Time_to_Control\",\n  \"SOP5_Time_to_Control\",\n  \"SOP6_Time_to_Control\",\n  \"SOP7_Time_to_Control\",\n  \"SOP8_Time_to_Control\",\n  \"SOP9_Time_to_Control\"\n];\n\nconst processingStepNames = [\n  \"SOP1_SOAR_Processing_Time\",\n  \"SOP2_SOAR_Processing_Time\",\n  \"SOP3_SOAR_Processing_Time\",\n  \"SOP4_SOAR_Processing_Time\",\n  \"SOP5_SOAR_Processing_Time\",\n  \"SOP6_SOAR_Processing_Time\",\n  \"SOP7_SOAR_Processing_Time\",\n  \"SOP8_SOAR_Processing_Time\",\n  \"SOP9_SOAR_Processing_Time\"\n];\n\nconst timeToControl = controlStepNames\n  .map(function(name) {\n    return $.Steps[name] ? $.Steps[name].data : null;\n  })\n  .find(function(value) {\n    return value != null;\n  }) || null;\n\nconst timeToProcess = processingStepNames\n  .map(function(name) {\n    return $.Steps[name] ? $.Steps[name].data : null;\n  })\n  .find(function(value) {\n    return value != null;\n  }) || null;\n\nconst invokeStatuses = Object.keys($.Steps)\n  .filter(function(name) {\n    return name.indexOf(\"Invoke\") === 0;\n  })\n  .map(function(name) {\n    return $.Steps[name] ? $.Steps[name].status : null;\n  })\n  .filter(function(status) {\n    return status != null;\n  });\n\nconst containmentSuccess =\n  invokeStatuses.length > 0 &&\n  invokeStatuses.every(function(status) {\n    return status === 200;\n  })\n    ? 1\n    : 0;\n\nreturn {\n  \"Execution Time\": $.Steps.Get_Alert_Data.data[0].attributes.attributes.full_alert.data.win.system.systemTime,\n  \"Time to Detect\": $.Steps.Time_to_Detect.data,\n  \"Time to Respond\": $.Steps.Time_to_Respond.data,\n  \"Time to Control\": timeToControl,\n  \"SOAR Processing Time\": timeToProcess,\n  \"Containment Success\": containmentSuccess,\n  \"Event Consumption\": Object.keys($.Steps).length + 1,\n  \"Cost per Execution\": 14 / 100\n};"
          }
        ],

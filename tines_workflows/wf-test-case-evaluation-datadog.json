    {
      "type": "Agents::EventTransformationAgent",
      "name": "Results Datadog per Execution",
      "disabled": false,
      "description": null,
      "guid": "a880c3bba4f06487955c2692660538b3",
      "origin_story_identifier": "cloud:0224858beecd9378f9a79657235a144b:7dbd4af7931cfcacae75912b902bdad3",
      "options": {
        "mode": "message_only",
        "loop": false,
        "payload": {
          "<<APPEND(\"run\",explode_executions.index+1)>>": {
            "Execution Time": "=DATE(get_datadog_execution_data.body.data.attributes.outputs.output['Execution Time'],\"%Y-%m-%d %H:%M:%S.%L\")",
            "Time to Detect": "=get_datadog_execution_data.body.data.attributes.outputs.output['Time to Detect']",
            "Time to Respond": "=get_datadog_execution_data.body.data.attributes.outputs.output['Time to Respond']",
            "Time to Control": "=get_datadog_execution_data.body.data.attributes.outputs.output['Time to Control']",
            "SOAR Processing Time": "=get_datadog_execution_data.body.data.attributes.outputs.output['SOAR Processing Time']",
            "Containment Success": "=get_datadog_execution_data.body.data.attributes.outputs.output['Containment Success']",
            "Event Consumption": "=SIZE(get_datadog_execution_data.body.data.attributes.stepStateAssociations)-1",
            "Cost per Execution": "=(14/100)*1"
          }
        }
      },
      "reporting": {
        "time_saved_value": 0,
        "time_saved_unit": "minutes"
      },

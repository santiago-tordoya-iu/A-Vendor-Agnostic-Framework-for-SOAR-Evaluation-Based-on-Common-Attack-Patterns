    {
      "type": "Agents::EventTransformationAgent",
      "name": "Results n8n per Execution",
      "disabled": false,
      "description": null,
      "guid": "40cc1c7b624d704fb46b9dcf01389e42",
      "origin_story_identifier": "cloud:0224858beecd9378f9a79657235a144b:236261b69a0ad4d1e7faf50a60261900",
      "options": {
        "mode": "message_only",
        "loop": false,
        "payload": "=MAP_LAMBDA(\n  implode_executions,\n  LAMBDA(\n    result,\n    OBJECT(\n      \"run\", KEYS(result)[0],\n      \"Execution Time\",\n      DEFAULT(\n        VALUES(result)[0].data.resultData.runData.Webhook[0].data.main[0][0].json.body.data.win.eventdata.utcTime,\n        DATE(VALUES(result)[0].data.resultData.runData.Webhook[0].data.main[0][0].json.body.data.win.system.systemTime,\"%Y-%m-%d %H:%M:%S.%L\")),\n      \"Time to Detect\",\n      VALUES(result)[0].data.resultData.runData['Time to Detect'][0].data.main[0][0].json.timeDifference.milliseconds,\n      \"Time to Respond\",VALUES(result)[0].data.resultData.runData['Time to Respond'][0].data.main[0][0].json.timeDifference.milliseconds,\n      \"Time to Control\",\n      VALUES(\n        REJECT(\n        VALUES(result)[0].data.resultData.runData,\n        LAMBDA(key, value, NOT(MATCH(key,\"Time to Control\")))))[0][0].data.main[0][0].json.timeDifference.milliseconds,\n      \"SOAR Processing Time\",\n      VALUES(\n        REJECT(\n        VALUES(result)[0].data.resultData.runData,\n        LAMBDA(key, value, NOT(MATCH(key,\"SOAR Processing Time\")))))[0][0].data.main[0][0].json.timeDifference.milliseconds,\n      \"Containment Success\",\n      REJECT(\n        VALUES(result)[0].data.resultData.runData,\n        LAMBDA(key, value, NOT(MATCH(key, \"Invoke\"))))\n      |> MAP(FLATTEN(VALUES(%)),\"executionStatus\")\n      |> IF(UNIQ(%)=[\"success\"],1,0),\n      \"Event Consumption\",\n      SIZE(VALUES(result)[0].data.resultData.runData),\n      \"Cost per Execution\",(24/2500)*1)\n    )\n  ) |>SORT(%, \"Execution Time\")"
      },
      "reporting": {
        "time_saved_value": 0,
        "time_saved_unit": "minutes"
      },
      "monitoring": {
        "monitor_all_events": false,
        "monitor_failures": false,
        "monitor_no_events_emitted": null
      },

    {
      "type": "Agents::EventTransformationAgent",
      "name": "ATTCK Detection Techniques",
      "disabled": false,
      "description": null,
      "guid": "1a1a9bd0f3ef21001ce5c15e465a960d",
      "origin_story_identifier": "cloud:0224858beecd9378f9a79657235a144b:0630ab7ced539f1fab4e7f0225af556a",
      "options": {
        "mode": "message_only",
        "loop": false,
        "payload": "=FILTER(\n  get_mitre_attck_stix.body.objects,\n  LAMBDA(obj, \n    AND(obj.type=\"attack-pattern\",\n      INCLUDES(MAP(obj.external_references,\"external_id\"), STRIP(submit_technique.body.technique_id)\n    ))))[0].id\n|>FILTER(\n  get_mitre_attck_stix.body.objects,\n  LAMBDA(obj, \nAND(\n  obj.type=\"relationship\",\n  obj.target_ref=%)))\n|> MAP_LAMBDA(\n  WHERE(%, \"relationship_type\", \"detects\"),\n  LAMBDA(\n    rel,\n    FILTER(\n      get_mitre_attck_stix.body.objects,\n      LAMBDA(obj, obj.id=rel.source_ref)))\n  )\n|> UNIQ(MAP_LAMBDA(\n  FLATTEN(%),\n  LAMBDA(det,\n    OBJECT(\"tactic\",\"Detect\",\n      \"technique\", APPEND(\"[\",det.name,\"](\",FILTER(det.external_references,LAMBDA(ref,ref.external_id))[0].url,\")\"))\n  )))"
      },
      "reporting": {

      "options": {
        "mode": "message_only",
        "loop": false,
        "payload": {
          "attck": "| Technique ID | Technique | Tactic |\n|---|---|---|\n|<<get_related_d3fend_techniques.attck_technique_id>>|<<get_related_d3fend_techniques.attck_technique>>|<<get_related_d3fend_techniques.attck_tactic>>|",
          "d3fend": "<%for tactic in SORT(UNIQ(MAP(get_related_d3fend_techniques.d3fend,\"tactic\")))%>|<<tactic>><<IF(FORLOOP.last, \"|\")>><%endfor%>\n<%for tactic in UNIQ(MAP(get_related_d3fend_techniques.d3fend,\"tactic\"))%>|---<<IF(FORLOOP.last, \"|\")>><%endfor%><%for counter in LAST(SORT(MAP_LAMBDA(UNIQ(MAP(get_related_d3fend_techniques.d3fend,\"tactic\")),LAMBDA(tactic,OBJECT(\"tactic\",tactic,\"techniques\",WHERE(get_related_d3fend_techniques.d3fend,\"tactic\",tactic),\"count\",SIZE(WHERE(get_related_d3fend_techniques.d3fend,\"tactic\",tactic))))),\"count\")).techniques%>\n<%for tactic in SORT(UNIQ(MAP(get_related_d3fend_techniques.d3fend,\"tactic\")))%>|<<WHERE(get_related_d3fend_techniques.d3fend,\"tactic\",tactic)[INDEX_OF(LAST(SORT(MAP_LAMBDA(UNIQ(MAP(get_related_d3fend_techniques.d3fend,\"tactic\")),LAMBDA(tactic,OBJECT(\"tactic\",tactic,\"techniques\",WHERE(get_related_d3fend_techniques.d3fend,\"tactic\",tactic),\"count\",SIZE(WHERE(get_related_d3fend_techniques.d3fend,\"tactic\",tactic))))),\"count\")).techniques,counter)].technique>><<IF(FORLOOP.last,\"|\")>><%endfor%><%endfor%>"
        }
      },

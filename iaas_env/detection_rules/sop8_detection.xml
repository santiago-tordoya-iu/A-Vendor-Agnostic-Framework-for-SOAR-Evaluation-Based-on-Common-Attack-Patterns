<group name="atomic_red_team">

  <rule id="100008" level="16">
    <if_group>sysmon</if_group>
    <field name="win.system.eventID" type="pcre2">^11$</field>

    <field name="win.eventdata.image" type="pcre2">(?i)powershell\.exe</field>
    <field name="win.eventdata.targetFilename" type="pcre2">(?i)ProgramData\\\\Microsoft\\\\Windows\\\\Start Menu\\\\Programs\\\\StartUp</field>

    <description>Atomic Red Team T1547.001 #4: PowerShell copied file to ProgramData Startup folder</description>
    <mitre>
      <id>T1547.001</id>
    </mitre>
     
    <options>no_full_log</options>
  </rule>

</group>

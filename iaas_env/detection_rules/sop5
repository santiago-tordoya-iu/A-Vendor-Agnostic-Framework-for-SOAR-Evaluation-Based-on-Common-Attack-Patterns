<group name="atomic_red_team,">

  <rule id="100005" level="16">
    <if_group>sysmon_event1</if_group>

    <field name="win.eventdata.image" type="pcre2">(?i)powershell\.exe</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(\$env:|Get-ChildItem env:| \[System\.Environment\]::UserName|USERNAME|USERDOMAIN)</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)Out-File</field>

    <description>Atomic Red Team T1033 #4: User Discovery via Environment Variables + Out-File</description>

    <mitre>
      <id>T1033</id>
    </mitre>

    <group>atomic_red_team,</group>
    <options>no_full_log</options>
  </rule>

</group>

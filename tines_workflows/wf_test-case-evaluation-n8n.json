    {
      "type": "Agents::EventTransformationAgent",
      "name": "Scorecard per SOP",
      "disabled": false,
      "description": null,
      "guid": "3ef5148567c27e7cf0c367227e8d531b",
      "origin_story_identifier": "cloud:0224858beecd9378f9a79657235a144b:236261b69a0ad4d1e7faf50a60261900",
      "options": {
        "mode": "message_only",
        "loop": false,
        "payload": {
          "test_case": "=SWITCH(\n  TRUE,\n  IS_PRESENT(sop1_executions),\n  \"SOP1\",\n  IS_PRESENT(sop2_executions),\n  \"SOP2\",\n  IS_PRESENT(sop3_executions),\n  \"SOP3\",\n  IS_PRESENT(sop4_executions),\n  \"SOP4\",\n  IS_PRESENT(sop5_executions),\n  \"SOP5\",\n  IS_PRESENT(sop6_executions),\n  \"SOP6\",\n  IS_PRESENT(sop7_executions),\n  \"SOP7\",\n  IS_PRESENT(sop7_executions),\n  \"SOP8\",\n  \"SOP9\"\n)",
          "mttd": "=AVERAGE(MAP(results_n8n_per_execution,\"['Time to Detect']\"))",
          "mttr": "=AVERAGE(MAP(results_n8n_per_execution,\"['Time to Respond']\"))",
          "mttc": "=AVERAGE(MAP(results_n8n_per_execution,\"['Time to Control']\"))",
          "mspt": "=AVERAGE(MAP(results_n8n_per_execution,\"['SOAR Processing Time']\"))",
          "csr": "=ROUND(AVERAGE(MAP(results_n8n_per_execution,\"['Containment Success']\"))*100,2)",
          "mec": "=AVERAGE(MAP(results_n8n_per_execution,\"['Event Consumption']\"))",
          "mcpe": "=AVERAGE(MAP(results_n8n_per_execution,\"['Cost per Execution']\"))"
        },
        "local": {
          "sop": "=SWITCH(\n  TRUE,\n  IS_PRESENT(sop1_executions),\n  \"SOP1\",\n  IS_PRESENT(sop2_executions),\n  \"SOP2\",\n  IS_PRESENT(sop3_executions),\n  \"SOP3\",\n  IS_PRESENT(sop4_executions),\n  \"SOP4\",\n  IS_PRESENT(sop5_executions),\n  \"SOP5\",\n  IS_PRESENT(sop6_executions),\n  \"SOP6\",\n  IS_PRESENT(sop7_executions),\n  \"SOP7\",\n  IS_PRESENT(sop7_executions),\n  \"SOP8\",\n  \"SOP9\"\n)"
        }
      },
      "reporting": {

    {
      "type": "Agents::EventTransformationAgent",
      "name": "Get related D3FEND techniques",
      "disabled": false,
      "description": null,
      "guid": "d65bdec5141cf9642aad3b6883da75a5",
      "origin_story_identifier": "cloud:a275b1e78883a96704277261c2a16488:6dcd9b1487fd74065a368cd0fc3b15fe",
      "options": {
        "mode": "message_only",
        "loop": false,
        "payload": "=FILTER(\n  get_mitre_d3fend.body.results.bindings,\n  LAMBDA(\n    binding,\n    AND(\nINCLUDES(['Detect', 'Evict','Restore'],binding.def_tactic_label.value),binding.off_tech_id.value=STRIP(submit_technique.body.technique_id)\n  )\n))\n|> OBJECT(\n  \"attck_technique_id\", APPEND(\"[\",%[0].off_tech_id.value,\"](https://attack.mitre.org/techniques/\",%[0].off_tech_id.value,\")\"),\n  \"attck_technique\", %[0].off_tech_label.value,\n  \"attck_tactic\", %[0].off_tactic_label.value,\n  \"d3fend\",\n  CONCAT(UNIQ(MAP_LAMBDA(%, LAMBDA(binding,\n    OBJECT(\n      \"tactic\",binding.def_tactic_label.value,\n      \"technique\",APPEND(\"[\",binding.def_tech_label.value,\"](https://d3fend.mitre.org/technique/d3f:\", SPLIT(binding.def_tech.value,\"#\")[1],\")\")\n      )\n    )\n  )), attck_detection_techniques)\n)"
      },
      "reporting": {
        "time_saved_value": 0,
        "time_saved_unit": "minutes"
      },
